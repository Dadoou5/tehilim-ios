    <!-- ==================== ABOUT — CONTENT SOURCES ==================== -->
    <string name="about_content_hebrew_title">Hebrew text</string>
    <string name="about_content_hebrew_body">The vocalized Hebrew text with teamim comes from Sefaria (sefaria.org), distributed under Creative Commons By 4.0.</string>
    <string name="about_content_fr_title">French translation</string>
    <string name="about_content_fr_body">The French translation comes from Beth Loubavitch (le-tehilim.online), used with their permission.</string>
    <string name="about_content_en_title">English translation</string>
    <string name="about_content_en_body">The English translation is the JPS Tanakh 1917, in the public domain and provided via Sefaria.</string>
    <string name="about_content_font_title">Hebrew typeface</string>
    <string name="about_content_font_body">The Hebrew display font is Ezra SIL SR, provided by SIL International under the SIL OFL license.</string>
    <string name="about_content_calendar_title">Hebrew calendar</string>
    <string name="about_content_calendar_body">Date conversions use the official Hebrew calendar via ICU (Unicode CLDR).</string>

    <!-- ==================== ABOUT — PRIVACY ==================== -->
    <string name="about_privacy_none_title">No data collected</string>
    <string name="about_privacy_none_body">Tehilim does not collect, transmit, or store any personal data.</string>
    <string name="about_privacy_local_title">Local storage</string>
    <string name="about_privacy_local_body">Your preferences (language, text size, favorites, last reading, Lelouy Nichmat) are stored locally on your device via Android DataStore, and backed up by Android Auto Backup if you enable Google cloud backup.</string>
    <string name="about_privacy_offline_title">Offline</string>
    <string name="about_privacy_offline_body">The app works entirely offline after installation — no network calls.</string>
    <string name="about_privacy_notifications_title">Notifications</string>
    <string name="about_privacy_notifications_body">Daily reminders use Android WorkManager and stay local. No push server is used.</string>
    <string name="about_privacy_thirdparty_title">Third parties</string>
    <string name="about_privacy_thirdparty_body">No tracker, no advertising, no third-party services of any kind.</string>
    <string name="about_privacy_contact_title">Contact</string>
    <string name="about_privacy_contact_body">For any question: david.bouganim@gmail.com</string>

    <!-- ==================== ACCESSIBILITY DECLARATION ==================== -->
    <string name="a11y_engagement_body">The Tehilim app is committed to making its content accessible in accordance with the French RGAA 4.1.2 reference and WCAG 2.1 level AA standards applicable to mobile apps.</string>
    <string name="a11y_status_main">Status: partial compliance (self-declaration).</string>
    <string name="a11y_status_secondary">This statement is based on a self-audit. An external audit is planned before production release.</string>
    <string name="a11y_feature_talkback">Full TalkBack compatibility.</string>
    <string name="a11y_feature_text_size">Respects the system text size (up to maximum accessibility scale).</string>
    <string name="a11y_feature_themes">Light, dark, and automatic modes.</string>
    <string name="a11y_feature_contrast">Text contrast meets AA level (≥ 4.5:1).</string>
    <string name="a11y_feature_targets">Tap targets equal to or greater than 48 × 48 dp.</string>
    <string name="a11y_feature_no_color_only">No information conveyed by color alone.</string>
    <string name="a11y_feature_animations">Respects the system “Remove animations” setting.</string>
    <string name="a11y_feature_rtl_ltr">TalkBack reads Hebrew in RTL direction and the translation in LTR, in that order.</string>
    <string name="a11y_limit_hebrew_tts">Hebrew text is read phonetically by TalkBack according to the capabilities of the voice chosen by the user.</string>
    <string name="a11y_limit_119_grid">The 22-letter grid of Tehilim 119 may require scrolling at very large text size.</string>
    <string name="a11y_recourse_body">To report an accessibility issue: contact to be defined before Google Play release.</string>
</resources>
