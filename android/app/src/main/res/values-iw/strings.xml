    <!-- ==================== ABOUT — PRIVACY ==================== -->
    <string name="about_privacy_none_title">לא נאסף מידע</string>
    <string name="about_privacy_none_body">תהילים אינה אוספת, משדרת או שומרת שום מידע אישי.</string>
    <string name="about_privacy_local_title">אחסון מקומי</string>
    <string name="about_privacy_local_body">ההעדפות שלכם (שפה, גודל טקסט, מועדפים, קריאה אחרונה, לעילוי נשמת) נשמרות מקומית במכשיר באמצעות Android DataStore, ומגובות על ידי Android Auto Backup אם הפעלתם גיבוי בענן של Google.</string>
    <string name="about_privacy_offline_title">ללא אינטרנט</string>
    <string name="about_privacy_offline_body">האפליקציה פועלת לחלוטין ללא אינטרנט לאחר ההתקנה — ללא קריאות רשת.</string>
    <string name="about_privacy_notifications_title">התראות</string>
    <string name="about_privacy_notifications_body">התזכורות היומיות משתמשות ב־WorkManager של Android ונשארות מקומיות. לא נעשה שימוש בשרת push.</string>
    <string name="about_privacy_thirdparty_title">צדדים שלישיים</string>
    <string name="about_privacy_thirdparty_body">ללא מעקב, ללא פרסומות, ללא שירותי צד שלישי מכל סוג.</string>
    <string name="about_privacy_contact_title">יצירת קשר</string>
    <string name="about_privacy_contact_body">לכל שאלה: david.bouganim@gmail.com</string>

