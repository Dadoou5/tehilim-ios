    <string name="about_content_hebrew_title">הטקסט העברי</string>
    <string name="about_content_hebrew_body">הטקסט העברי המנוקד עם הטעמים מגיע מספריא (sefaria.org), בהפצה תחת רישיון Creative Commons By 4.0.</string>
    <string name="about_content_fr_title">התרגום הצרפתי</string>
    <string name="about_content_fr_body">התרגום הצרפתי מגיע מבית ליובאוויטש (le-tehilim.online), בשימוש באישורם.</string>
    <string name="about_content_en_title">התרגום האנגלי</string>
    <string name="about_content_en_body">התרגום האנגלי הוא JPS Tanakh 1917, בנחלת הכלל, באמצעות ספריא.</string>
    <string name="about_content_font_title">הגופן העברי</string>
    <string name="about_content_font_body">גופן התצוגה העברי הוא Ezra SIL SR, מבית SIL International תחת רישיון SIL OFL.</string>
    <string name="about_content_calendar_title">הלוח העברי</string>
