    <!-- ==================== ABOUT — CONTENT SOURCES ==================== -->
    <string name="about_content_hebrew_title">Texte hébreu</string>
    <string name="about_content_hebrew_body">Le texte hébreu vocalisé avec téamim provient de Sefaria (sefaria.org), distribué sous licence Creative Commons By 4.0.</string>
    <string name="about_content_fr_title">Traduction française</string>
    <string name="about_content_fr_body">La traduction française provient de Beth Loubavitch (le-tehilim.online), utilisée avec leur autorisation.</string>
    <string name="about_content_en_title">Traduction anglaise</string>
    <string name="about_content_en_body">La traduction anglaise est la JPS Tanakh 1917, dans le domaine public et fournie via Sefaria.</string>
    <string name="about_content_font_title">Police hébraïque</string>
    <string name="about_content_font_body">La police d\'affichage de l\'hébreu est Ezra SIL SR, fournie par SIL International sous licence SIL OFL.</string>
    <string name="about_content_calendar_title">Calendrier hébraïque</string>
    <string name="about_content_calendar_body">Les conversions de date utilisent le calendrier hébraïque officiel via ICU (Unicode CLDR).</string>

    <!-- ==================== ABOUT — PRIVACY ==================== -->
    <string name="about_privacy_none_title">Aucune donnée collectée</string>
    <string name="about_privacy_none_body">Tehilim ne collecte, ne transmet ni ne stocke aucune donnée personnelle.</string>
    <string name="about_privacy_local_title">Stockage local</string>
    <string name="about_privacy_local_body">Tes préférences (langue, taille du texte, favoris, dernière lecture, Lelouy Nichmat) sont stockées localement sur ton appareil via Android DataStore, et sauvegardées par Android Auto Backup si tu actives la sauvegarde cloud Google.</string>
    <string name="about_privacy_offline_title">Hors-ligne</string>
    <string name="about_privacy_offline_body">L\'app fonctionne entièrement hors-ligne après installation — aucun appel réseau.</string>
    <string name="about_privacy_notifications_title">Notifications</string>
    <string name="about_privacy_notifications_body">Les rappels quotidiens utilisent WorkManager Android et restent locaux. Aucun serveur push n\'est utilisé.</string>
    <string name="about_privacy_thirdparty_title">Tiers</string>
    <string name="about_privacy_thirdparty_body">Aucun tracker, aucune publicité, aucun service tiers de quelque nature que ce soit.</string>
    <string name="about_privacy_contact_title">Contact</string>
    <string name="about_privacy_contact_body">Pour toute question : david.bouganim@gmail.com</string>

    <!-- ==================== ACCESSIBILITY DECLARATION ==================== -->
    <string name="a11y_engagement_body">L\'application Tehilim s\'engage à rendre son contenu accessible conformément au Référentiel Général d\'Amélioration de l\'Accessibilité (RGAA 4.1.2) et au standard WCAG 2.1 niveau AA, applicables aux applications mobiles.</string>
    <string name="a11y_status_main">Statut : conformité partielle (auto-déclaration).</string>
    <string name="a11y_status_secondary">Cette déclaration est établie sur la base d\'un auto-audit. Un audit externe est prévu avant la mise en production.</string>
    <string name="a11y_feature_talkback">Compatibilité complète avec TalkBack.</string>
    <string name="a11y_feature_text_size">Respect de la taille de texte système (jusqu\'à l\'échelle accessibilité maximale).</string>
    <string name="a11y_feature_themes">Modes clair, sombre, et automatique.</string>
    <string name="a11y_feature_contrast">Contrastes de texte conformes au niveau AA (≥ 4.5:1).</string>
    <string name="a11y_feature_targets">Cibles tactiles supérieures ou égales à 48 × 48 dp.</string>
    <string name="a11y_feature_no_color_only">Aucune information transmise uniquement par la couleur.</string>
    <string name="a11y_feature_animations">Respect du paramètre « Supprimer les animations » du système.</string>
    <string name="a11y_feature_rtl_ltr">Lecture TalkBack de l\'hébreu en sens RTL et de la traduction en LTR, dans cet ordre.</string>
    <string name="a11y_limit_hebrew_tts">Le texte hébreu est lu phonétiquement par TalkBack selon les capacités de la voix sélectionnée par l\'utilisateur·rice.</string>
    <string name="a11y_limit_119_grid">La grille des 22 lettres du Tehilim 119 peut nécessiter un défilement avec une très grande taille de texte.</string>
    <string name="a11y_recourse_body">Pour signaler un problème d\'accessibilité : contact à définir avant publication Google Play.</string>
