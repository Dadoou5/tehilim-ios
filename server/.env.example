# ============================================================================
# Backend Tehilim (VPS) — variables d'environnement.
# Copier en .env sur le serveur (/var/www/tehilim/.env), perms 600.
# NE JAMAIS committer .env. Aucune valeur secrète ici.
# Chargé par Node via --env-file (voir ecosystem.config.cjs).
# ============================================================================

# --- Process api ---
PORT=3000
# Secret partagé protégeant POST /internal/notify.
# DOIT être égal à private.config.notify_secret côté Supabase
# (récupérer : select value from private.config where key='notify_secret';)
NOTIFY_SHARED_SECRET=

# --- Supabase (purge des tokens push morts via REST service-role) ---
SUPABASE_URL=https://ymhbmhnuniaxhhsckdaq.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# --- APNs (iOS) — repris des secrets actuels de l'Edge Function ---
# RECOMMANDÉ : scp le fichier .p8 sur le serveur et donner son chemin.
APNS_KEY_P8_PATH=/var/www/tehilim/secrets/apns.p8
# (alternative inline : APNS_KEY_P8=-----BEGIN PRIVATE KEY-----\n...\n-----END...)
APNS_KEY_ID=          # ex. ABC123DEF4 (nom du fichier AuthKey_XXXXXXXXXX.p8)
APNS_TEAM_ID=         # Apple Developer → Membership → Team ID
APNS_BUNDLE_ID=       # ex. com.david.tehilim (identifiant de l'app iOS)
# Production par défaut ; api.sandbox.push.apple.com pour les builds debug.
APNS_HOST=api.push.apple.com

# --- FCM (Android) ---
# RECOMMANDÉ : scp le JSON du service account et donner son chemin.
FCM_SERVICE_ACCOUNT_PATH=/var/www/tehilim/secrets/fcm-service-account.json
# (alternative inline : FCM_SERVICE_ACCOUNT={"type":"service_account",...})
FCM_PROJECT_ID=       # ex. tehilim-xxxxx (champ project_id du JSON)

# --- Process scheduler (phase 2) ---
# Connexion Postgres DIRECTE Supabase, session mode (port 5432, PAS le pooler 6543).
# Supabase → Project Settings → Database → Connection string → URI (session).
# Ex : postgresql://postgres:<password>@db.ymhbmhnuniaxhhsckdaq.supabase.co:5432/postgres
DATABASE_URL=
