{
  "name": "tehilim-backend",
  "version": "1.0.0",
  "private": true,
  "description": "Backend self-hosté Tehilim (VPS) — worker push APNs/FCM + scheduler. Réduit la dépendance aux Edge Functions / pg_cron Supabase.",
  "license": "UNLICENSED",
  "type": "commonjs",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start:api": "node dist/api.js",
    "start:scheduler": "node dist/scheduler.js",
    "start:realtime": "node dist/realtime.js",
    "dev:api": "tsx watch src/api.ts",
    "dev:scheduler": "tsx watch src/scheduler.ts",
    "dev:realtime": "tsx watch src/realtime.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "express": "^4.21.2",
    "jsonwebtoken": "^9.0.2",
    "node-cron": "^3.0.3",
    "pg": "^8.13.1",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^22.10.5",
    "@types/node-cron": "^3.0.11",
    "@types/pg": "^8.11.10",
    "@types/ws": "^8.5.13",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
