# ============================================================================
# Test de charge « sélection d'un Tehilim dans une chaîne » — configuration
# Copier en `.env` puis `source tests/load/.env` (ou laisser run.sh le charger).
# ============================================================================

# --- Cible Supabase (OBLIGATOIRE) -------------------------------------------
# URL du projet + clé ANON (publique, protégée par la RLS — pas la service_role).
SUPABASE_URL=https://ymhbmhnuniaxhhsckdaq.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...REMPLACER...

# --- Topologie de charge -----------------------------------------------------
NUM_CHAINS=10          # chaînes parallèles
USERS_PER_CHAIN=20     # VUs par chaîne  → VUS total = 10 * 20 = 200

# --- Durées (format k6) ------------------------------------------------------
RAMP_UP=2m
PLATEAU=10m
RAMP_DOWN=2m

# --- Comportement utilisateur ------------------------------------------------
THINK_MIN_MS=500       # délai mini entre deux actions
THINK_MAX_MS=2000      # délai maxi entre deux actions
SELECTION_WINDOW_S=3600 # fenêtre de sélection ouverte (doit couvrir tout le test)

# --- Scénario de collision ---------------------------------------------------
COLLISION_VUS=20       # utilisateurs simultanés sur la MÊME chaîne
COLLISION_PSALMS=30    # nb de psaumes disputés simultanément

# --- Divers ------------------------------------------------------------------
SCENARIO=distribution  # distribution | collision | both
TEST_TAG=LOADTEST      # préfixe des données de test (cleanup ciblé)
